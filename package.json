{
  "name": "integrated-browser-mcp",
  "displayName": "Integrated Browser MCP",
  "description": "Exposes VS Code's integrated browser to external agents (Claude Code, scripts, curl) via a local HTTP API and MCP server.",
  "version": "0.5.0",
  "publisher": "thimo",
  "license": "MIT",
  "author": {
    "name": "Thimo Jansen"
  },
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/thimo/integrated-browser-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/thimo/integrated-browser-mcp/issues"
  },
  "homepage": "https://github.com/thimo/integrated-browser-mcp#readme",
  "keywords": [
    "mcp",
    "browser",
    "claude",
    "claude-code",
    "automation",
    "cdp",
    "chrome-devtools-protocol",
    "agent",
    "ai"
  ],
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "AI",
    "Debuggers",
    "Other"
  ],
  "enabledApiProposals": [
    "browser"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "browserBridge.start",
        "title": "Browser Bridge: Start"
      },
      {
        "command": "browserBridge.stop",
        "title": "Browser Bridge: Stop"
      },
      {
        "command": "browserBridge.status",
        "title": "Browser Bridge: Show Status"
      },
      {
        "command": "browserBridge.openInBrowser",
        "title": "Open in Integrated Browser"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "browserBridge.openInBrowser",
          "when": "resourceExtname == .html || resourceExtname == .htm || resourceExtname == .pdf || resourceExtname == .svg",
          "group": "navigation@30"
        }
      ],
      "editor/title/context": [
        {
          "command": "browserBridge.openInBrowser",
          "when": "resourceExtname == .html || resourceExtname == .htm || resourceExtname == .pdf || resourceExtname == .svg",
          "group": "1_open@30"
        }
      ]
    },
    "configuration": {
      "title": "Browser Bridge",
      "properties": {
        "browserBridge.httpPort": {
          "type": "number",
          "default": 3788,
          "description": "Port for the local HTTP API server"
        },
        "browserBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the bridge when VS Code opens"
        },
        "browserBridge.browserType": {
          "type": "string",
          "default": "editor-browser",
          "enum": ["editor-browser", "chrome"],
          "enumDescriptions": [
            "VS Code integrated browser (runs inside VS Code)",
            "External Chrome window (more reliable CDP support)"
          ],
          "description": "Which browser type to launch for automation"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.mcp.json",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.2",
    "ws": "^8.18.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.112.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
